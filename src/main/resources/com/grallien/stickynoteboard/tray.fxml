<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>

<?import javafx.scene.layout.StackPane?>
<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           styleClass="tray-root"
           fx:id="mainContainer"
           fx:controller="com.grallien.stickynoteboard.TrayController">
    <children>
        <VBox prefWidth="450"
              prefHeight="800"
              style="-fx-background-color: transparent"
              fx:id="rootPane">
            <children>
                <!-- Interactive Top Bar -->
                <HBox alignment="CENTER_RIGHT"
                      prefHeight="50"
                      style="-fx-padding:10 15 10 15;">
                    <children>
                        <Button text="+"
                                styleClass="tray-button"
                                onAction="#handleCreateNewNote">
                        </Button>
                        <Button text="⚙"
                                styleClass="tray-button"
                                onAction="#handleSettings">
                        </Button>
                    </children>
                </HBox>

                <!-- Sticky Notes Canvas -->
                <AnchorPane fx:id="canvasArea"
                            VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent">

                </AnchorPane>
            </children>

        </VBox>
    </children>
</StackPane>