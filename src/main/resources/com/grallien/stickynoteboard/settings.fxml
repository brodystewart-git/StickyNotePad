<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.grallien.stickynoteboard.SettingsController"
      alignment="CENTER" spacing="10" style="-fx-padding: 20;">
    <Label text="Select Skin" style="-fx-font-weight: bold; -fx-font-size: 16;" />

    <ListView fx:id="skinListView" prefHeight="200" prefWidth="200" />

    <Button text="Apply Skin" onAction="#handleApply" />
</VBox>